#pragma once

#include <QObject>
#include <QHash>
#include <QString>
#include <QVector>
#include <QDebug>
#include <QUuid>

#include "header.h"
#include "playlist.h"

class PlaylistManager : public QObject
{
    Q_OBJECT;
public:
    explicit PlaylistManager(QObject *parent = nullptr);
    ~PlaylistManager();

// Playlist management
public:
    void clearList();
    void createList();
    void loadList(const QString& filepath);
    void removeList(QUuid& uuid);
    void copyList(const QUuid& src);
    Playlist* findPlaylistById(const QUuid& uuid);

    void addTrackToPlaylist(const QUuid& playlistId, const QString& filepath);
    bool isEmpty();
private:
    QVector<Playlist> m_list;

// Playlist view
public:
    void sortByAlbum();

private:
    QVector<QUuid> m_playbackQueue;
    QHash<QUuid, TrackMetaData> m_metaRepo;

// Play state management
public:
    void setPlayMode(PlayMode mode);
    
private:
    Playlist m_currentPlaylist;
    Track m_currentTrack;
    
signals:
    void playbackQueueChanged();
    void updatePlaylist();
};
